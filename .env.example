# Copy to ".env" in the project root. Never commit real keys.

# --- Recommended: Sarvam AI (India) — get key at https://dashboard.sarvam.ai/key-management
SARVAM_API_KEY=your-sarvam-key
# Optional: model (default sarvam-30b). See https://docs.sarvam.ai/api-reference-docs/getting-started/models
# SARVAM_CHAT_MODEL=sarvam-30b
# SARVAM_API_BASE=https://api.sarvam.ai/v1

# --- Optional: OpenAI instead (only if SARVAM_API_KEY is unset)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_CHAT_MODEL=gpt-4o-mini

# DEMO_MODE=1
# RAG_FAST=1
# RAG_SKIP_INTAKE_LLM=1
# LLM_TEMPERATURE=0.25
